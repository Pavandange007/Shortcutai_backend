# Copy to .env and fill in values. Pydantic reads these (case-insensitive names).

API_CORS_ALLOW_ORIGIN=*

UPLOADS_ROOT=./data/uploads
OUTPUTS_ROOT=./data/outputs

GEMINI_API_KEY=

# medium/large = better quality; base/tiny = much faster on CPU for dev
WHISPER_MODEL_NAME=medium
# Use cpu if no NVIDIA GPU / CUDA
GPU_DEVICE=cuda:0

# Use at least 32 random bytes/characters in production
AUTH_SECRET=dev-change-me-dev-change-me-dev-change-me-2026
AUTH_TOKEN_TTL_SECONDS=1209600
